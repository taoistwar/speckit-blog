---
layout: layouts/base.njk
title: Tags
---

<section class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">All Tags</h1>
  <p class="text-gray-600 mt-2">Browse posts by topic</p>
</section>

<section class="flex flex-wrap gap-3">
  {% for tag in collections | keys %}
    {% if tag != "all" and tag != "post" and tag != "posts" %}
      <a href="/tags/{{ tag | slugify }}/" class="px-4 py-2 bg-gray-100 text-gray-800 rounded-lg hover:bg-gray-200 transition">
        {{ tag }}
        <span class="ml-1 text-gray-500">({{ collections[tag].length }})</span>
      </a>
    {% endif %}
  {% endfor %}
</section>
