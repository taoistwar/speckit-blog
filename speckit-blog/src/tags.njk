---
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - posts
    - post
permalink: /tags/{{ tag | slugify }}/
layout: layouts/tag.njk
---

<section class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Posts tagged "{{ tag }}"</h1>
  <p class="text-gray-600 mt-2">{{ collections[tag].length }} post{% if collections[tag].length != 1 %}s{% endif %}</p>
</section>

<section class="space-y-8">
  {% set posts_list = collections[tag] | reverse %}
  {% for post in posts_list %}
  <article class="border-b border-gray-200 pb-6">
    <h2 class="text-xl font-semibold mb-2">
      <a href="{{ post.url }}" class="text-gray-900 hover:text-primary-600">{{ post.data.title }}</a>
    </h2>
    <div class="text-sm text-gray-500">
      <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
    </div>
    {% if post.data.excerpt %}
      <p class="mt-2 text-gray-700">{{ post.data.excerpt }}</p>
    {% endif %}
  </article>
  {% endfor %}
</section>
