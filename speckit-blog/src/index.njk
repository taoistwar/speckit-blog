---
layout: layouts/base.njk
title: Home
---

<section class="mb-12">
  <h1 class="text-4xl font-bold text-gray-900 mb-4">Latest Posts</h1>
  <p class="text-gray-600">Welcome to my blog. Here I write about technology, programming, and life.</p>
</section>

<section class="space-y-8">
  {% for post in collections.posts %}
  <article class="border-b border-gray-200 pb-8">
    <h2 class="text-2xl font-semibold mb-2">
      <a href="{{ post.url }}" class="text-gray-900 hover:text-primary-600">{{ post.data.title }}</a>
    </h2>
    <div class="text-sm text-gray-500 mb-3">
      <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
      {% if post.data.tags %}
        <span class="mx-2">|</span>
        <span class="space-x-2">
          {% for tag in post.data.tags %}
            {% if tag != "post" %}
              <a href="/tags/{{ tag | slugify }}/" class="text-primary-600 hover:text-primary-700">{{ tag }}</a>
            {% endif %}
          {% endfor %}
        </span>
      {% endif %}
    </div>
    {% if post.data.excerpt %}
      <p class="text-gray-700">{{ post.data.excerpt }}</p>
    {% endif %}
    <a href="{{ post.url }}" class="inline-block mt-3 text-primary-600 hover:text-primary-700 text-sm font-medium">
      Read more →
    </a>
  </article>
  {% endfor %}
</section>

{% if collections.posts.length === 0 %}
<p class="text-gray-600">No posts yet. Check back soon!</p>
{% endif %}
