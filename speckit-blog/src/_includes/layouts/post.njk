---
layout: layouts/base.njk
---
<article class="max-w-3xl mx-auto">
  <header class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">{{ title }}</h1>
    <div class="text-gray-500">
      <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      {% if author %}
        <span class="mx-2">by</span>
        <span>{{ author }}</span>
      {% endif %}
    </div>
    {% if tags %}
      <div class="mt-4 flex flex-wrap gap-2">
        {% for tag in tags %}
          {% if tag != "post" %}
            <a href="/tags/{{ tag | slugify }}/" class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm hover:bg-gray-200">
              {{ tag }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </header>

  <div class="prose prose-lg max-w-none">
    {{ content | safe }}
  </div>

  <footer class="mt-12 pt-8 border-t border-gray-200">
    <a href="/" class="text-primary-600 hover:text-primary-700 font-medium">← Back to home</a>
  </footer>
</article>
